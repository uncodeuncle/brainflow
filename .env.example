# ====== 路径配置 (适配个人服务器) ======
# 如果您不打算部署在根域名 (比如部署在 /tools/brainflow )，请填写此项
NEXT_PUBLIC_BASE_PATH=/tools/brainflow

# ====== Redis 配置 ======
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ====== 阿里云全局凭证 (核心！！) ======
# 请务必使用 RAM 子用户的 AccessKey，【严禁】使用阿里云主账号
ALIYUN_ACCESS_KEY_ID=your_ram_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_ram_access_key_secret

# ====== 阿里云 OSS 直传配置 (v0.2.0 新增) ======
# 用于在前端直接安全上传本地大文件，不耗费此服务器带宽
# 格式要求：acs:ram::您的主账号UID:role/您的RAM角色名称
ALIYUN_STS_ROLE_ARN=acs:ram::1234567890:role/brainflowuploader
# OSS Bucket 区域 (例如: oss-cn-shenzhen)
ALIYUN_OSS_REGION=oss-cn-shenzhen
# OSS Bucket 名称
ALIYUN_OSS_BUCKET=your_bucket_name

# ====== 阿里云百炼 DashScope API KEY (语音极速识别服务) ======
DASHSCOPE_API_KEY=your_dashscope_api_key

# ====== DeepSeek API ======
# 用于生成知识图谱、总结与结构化拆解
DEEPSEEK_API_KEY=sk-yourdeepseekkey

# ====== Bilibili 身份验证 (选填) ======
# 填入 SESSDATA 用于跳过前端扫码环节强制校验（不推荐公开部署时填写）
# BILIBILI_SESSION_TOKEN=your_bilibili_sessdata
